          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "title": "DB query latency p95 (1s ceiling)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (service, le) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{service}}",
          "refId": "A"
        }
      ]
    }
