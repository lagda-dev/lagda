{
  "name": "@lagda/auth",
  "version": "0.1.0",
  "private": true,
  "description": "Lagda identity & token service — Better Auth: sign-in, email OTP, organizations/roles, JWT/JWKS, and scoped application tokens",
  "license": "AGPL-3.0-only",
  "type": "module",
  "exports": {
    ".": "./src/auth.ts"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.2",
    "@lagda/auth-contract": "workspace:*",
    "@lagda/core": "workspace:*",
    "@lagda/logger": "workspace:*",
    "@lagda/observability": "workspace:*",
    "better-auth": "~1.2.12",
    "hono": "^4.6.5",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^1.6.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  }
}
