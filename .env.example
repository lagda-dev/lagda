# Shared
LOG_LEVEL=info

# Application service (apps/server)
# Ports are left to each app's default in local dev (server 3000, auth 3100) — do not set a shared
# PORT here or both apps would bind the same port. Override per-process if you need to.
DATABASE_URL=postgres://lagda:lagda@localhost:5432/lagda
# JWKS endpoint of the auth service used to verify bearer tokens
AUTH_JWKS_URL=http://localhost:3100/api/auth/jwks
# Rate limiting (per token + per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GLOBAL=120
RATE_LIMIT_WRITE=30

# Auth service (apps/auth) — the token authority
AUTH_BASE_URL=http://localhost:3100
# Dedicated auth database; falls back to DATABASE_URL when unset
# AUTH_DATABASE_URL=postgres://lagda:lagda@localhost:5432/lagda_auth

# SMTP for OTP email delivery. REQUIRED in production — the auth service fails fast at startup without
# it, because email-OTP gates every sign-in and the sign-up email verification. In development you can
# leave these unset: the OTP is printed to the auth logs instead (and owner@lagda.local is always 123456).
# Works with any provider (SES, Mailgun, Postmark, a company relay, …). Credentials are optional — set
# SMTP_USER and SMTP_PASSWORD together, or neither for an IP-allowlisted/open relay.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=Lagda <no-reply@example.com>

# Observability (docker-compose.observability.yml) — all optional
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# LOKI_URL=http://localhost:3102
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
# SLACK_ALERT_WEBHOOK_URL=
